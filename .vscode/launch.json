{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run Steinmetz Report",
      "program": "${workspaceFolder}/scripts/dev-server.mjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "serverReadyAction": {
        "pattern": "running at (http://localhost:[0-9]+/)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open Existing Steinmetz Server",
      "url": "http://localhost:4173/",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
